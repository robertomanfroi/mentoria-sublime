# ── Servidor ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Segurança (OBRIGATÓRIO em produção) ─────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── Admin (OBRIGATÓRIO em produção) ─────────────────────────
# Credenciais do usuário administrador criado no primeiro boot
# Se não definido em produção, o seed de admin é pulado
ADMIN_EMAIL=admin@suaempresa.com
ADMIN_PASSWORD=

# Senha padrão das mentoradas de exemplo (apenas desenvolvimento)
# SAMPLE_USER_PASSWORD=senha123

# ── CORS ────────────────────────────────────────────────────
# Origens permitidas separadas por vírgula
# Em desenvolvimento: http://localhost:5173
# Em produção: https://mentoria-sublime.onrender.com
CORS_ORIGIN=http://localhost:5173

# ── Banco de dados (opcional — padrão: SQLite local) ─────────
# Para usar Turso em produção:
# TURSO_DATABASE_URL=libsql://seu-banco.turso.io
# TURSO_AUTH_TOKEN=seu-token

# ── Uploads ──────────────────────────────────────────────────
# Caminho absoluto para a pasta de uploads (padrão: ./uploads)
# UPLOADS_PATH=/data/uploads

# ── Frontend build (opcional) ────────────────────────────────
# CLIENT_BUILD_PATH=/app/client/dist
